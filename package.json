{
  "name": "appkeep",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/server.js",
    "preserve": "node scripts/credentials.js",
    "serve": "ng serve",
    "prebuild": "node scripts/credentials.js",
    "build": "ng build --configuration production",
    "preserve:prod": "npm run build",
    "serve:prod": "http-server -p 4000 --proxy http://localhost:3000 dist/appkeep",
    "test": "vitest",
    "test:coverage": "vitest --watch=false --coverage.enabled=true",
    "test:ci": "vitest --watch=false --coverage.enabled=true",
    "lint": "ng lint --fix",
    "e2e": "dotenv -e .env.e2e -- playwright test",
    "e2e:docker": "docker compose -f docker-compose.e2e.yml up -d --build --wait && dotenv -e .env.e2e -- playwright test --config playwright.docker.config.ts; docker compose -f docker-compose.e2e.yml down",
    "postinstall": "npm run prebuild && ng build --configuration production",
    "icons": "reload -b -s icons.html -e svg,html -d src/ -p 9000",
    "prepatterns": "sass src/styles.scss src/patterns.css -I . --no-source-map",
    "patterns": "reload -b -s patterns.html -e svg,css,html -d src/ -p 9001"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.9.2"
  },
  "private": true,
  "dependencies": {
    "@abacritt/angularx-social-login": "2.4.0",
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/pwa": "^21.2.17",
    "@angular/router": "^21.2.6",
    "@angular/service-worker": "^21.2.6",
    "compression": "^1.7.4",
    "cron": "^1.8.2",
    "dexie": "^4.4.4",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-sslify": "^1.2.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "mongoose": "^9.7.2",
    "node-schedule": "^1.3.2",
    "path": "^0.12.7",
    "rxjs": "7.8.2",
    "tslib": "^2.0.0",
    "vitest": "^3.2.4",
    "web-push": "^3.4.1"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.6.1",
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@analogjs/vitest-angular": "^2.6.1",
    "@angular-devkit/build-angular": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/language-service": "^21.2.6",
    "@playwright/test": "^1.58.2",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "24.0.10",
    "@vitest/coverage-v8": "^3.2.4",
    "angular-eslint": "20.1.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.29.0",
    "http-server": "^14.1.1",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "jsdom": "^22.0.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "reload": "^3.0.3",
    "sass-planifolia": "^0.6.0",
    "ts-node": "~10.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.0.2",
    "vite-tsconfig-paths": "^4.2.0"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "esbuild": "^0.28.1",
    "undici": "^7.28.0",
    "ws": "^8.21.0",
    "http-proxy-middleware": "^3.0.7",
    "js-yaml": "^4.2.0"
  }
}
